<base:UserControlBase
    x:Class="MergePDF.View.InformationUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MergePDF.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="*,auto">
        <!--  Inhalte zum UserControl  -->
        <Border Background="#FAFAFB" CornerRadius="5">
            <Grid
                Margin="10"
                ColumnDefinitions="160, *"
                RowDefinitions="40,25,25,25,25, 25, 25,25,25">
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,10"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,2">
                    <TextBlock
                        HorizontalAlignment="Left"
                        FontSize="16"
                        FontWeight="Medium">
                        <Run Text="Information zu" />
                        <Run
                            FontWeight="Bold"
                            Foreground="Blue"
                            Text="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}" />
                    </TextBlock>
                </Border>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Applikation Version" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{Binding Path=ApplicationVersion, FallbackValue=~ApplicationVersion}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="Runtime Version" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Text="{Binding Path=LaufzeitVersion, FallbackValue=~LaufzeitVersion}" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    Text="Windows Version" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Text="{Binding Path=WinVersion, FallbackValue=~WinVersion}" />

                <Border
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,5"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,2" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    Text="App Installationsverzeichnis" />

                <TextBox
                    Grid.Row="4"
                    Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    IsReadOnly="True"
                    Text="{Binding Path=InstallFolder, FallbackValue=~InstallFolder}" />

                <TextBlock
                    Grid.Row="5"
                    Grid.Column="0"
                    Text="App Settingsverzeichnis" />

                <TextBox
                    Grid.Row="5"
                    Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    IsReadOnly="True"
                    Text="{Binding Path=SettingsFolder, FallbackValue=~SettingsFolder}" />

                <Border
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,5"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,2" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    Text="Gesamtes RAM" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="1"
                    Text="{Binding Path=TotalRAM, FallbackValue=~TotalRAM}" />

                <TextBlock
                    Grid.Row="7"
                    Grid.Column="0"
                    Text="Freies RAM" />

                <TextBlock
                    Grid.Row="7"
                    Grid.Column="1"
                    Text="{Binding Path=FreeRAM, FallbackValue=~FreeRAM}" />

                <TextBlock
                    Grid.Row="8"
                    Grid.Column="0"
                    Text="Belegtes RAM (durch App)" />

                <TextBlock
                    Grid.Row="8"
                    Grid.Column="1"
                    Text="{Binding Path=UsedRAM, FallbackValue=~UsedRAM}" />
            </Grid>
        </Border>
    </Grid>
</base:UserControlBase>
