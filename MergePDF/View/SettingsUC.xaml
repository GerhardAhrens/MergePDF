<base:UserControlBase
    x:Class="MergePDF.View.SettingsUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MergePDF.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*,auto" RowDefinitions="40,Auto">
        <!--  Inhalte zum UserControl  -->
        <Border Background="#FAFAFB" CornerRadius="5">
            <Grid
                Margin="10"
                ColumnDefinitions="120, *"
                RowDefinitions="40,25,25,25">
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,10"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,2">
                    <TextBlock
                        HorizontalAlignment="Left"
                        FontSize="16"
                        FontWeight="Bold">
                        <Run Text="Einstellungen zu" />
                        <Run Text="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}" />
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <GroupBox
            x:Name="AppplicationSettings"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5"
            Padding="5">
            <GroupBox.Template>
                <ControlTemplate TargetType="GroupBox">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </GroupBox.Template>
            <Grid
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                ColumnDefinitions="150, *"
                RowDefinitions="30,40">
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Nachfragen beim Beenden" />

                <base:YesNoComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    ResultSelection="{Binding Path=SelectionExitAnswer, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            </Grid>

        </GroupBox>
    </Grid>
</base:UserControlBase>
