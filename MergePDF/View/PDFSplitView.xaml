<base:UserControlBase
    x:Class="MergePDF.View.PDFSplitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:core="clr-namespace:MergePDF.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MergePDF.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <system:Double x:Key="ButtonSize">40</system:Double>
    </UserControl.Resources>

    <Grid
        x:Name="gridMain"
        Background="WhiteSmoke"
        ColumnDefinitions="*"
        RowDefinitions="Auto,*">

        <!--#region Hauptmenübar-->
        <GroupBox
            x:Name="MainMenubar"
            Grid.Row="0"
            Margin="5"
            Padding="5">
            <GroupBox.Template>
                <ControlTemplate TargetType="GroupBox">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </GroupBox.Template>
            <DockPanel Grid.Row="0" Grid.Column="0">
                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=GoBackCommand}"
                    CommandParameter="{x:Static core:CommandButtons.GoBack}"
                    ToolTip="Zurück">
                    <Image Source="{StaticResource ResourceKey=IconGoBack}" Stretch="Uniform" />
                </Button>

                <Border
                    Width="1"
                    Margin="5,0,0,0"
                    Background="Gray" />

                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=OpenFolderCommand}"
                    CommandParameter="{x:Static core:CommandButtons.OpenFolder}"
                    ToolTip="Ordner öffnen">
                    <Image Source="{StaticResource ResourceKey=IconOffice_Folder_open_64}" Stretch="Uniform" />
                </Button>

            </DockPanel>
        </GroupBox>

        <!--#endregion Hauptmenübar-->
    </Grid>
</base:UserControlBase>
