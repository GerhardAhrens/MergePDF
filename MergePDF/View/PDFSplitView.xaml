<base:UserControlBase
    x:Class="MergePDF.View.PDFSplitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:core="clr-namespace:MergePDF.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MergePDF.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <system:Double x:Key="ButtonSize">40</system:Double>
    </UserControl.Resources>

    <Grid
        x:Name="gridMain"
        Background="WhiteSmoke"
        ColumnDefinitions="*"
        RowDefinitions="Auto,*">

        <!--#region Drag and Drop Popup-->
        <Popup
            x:Name="DragDropPopup"
            AllowsTransparency="True"
            IsHitTestVisible="False"
            Placement="Relative">

            <Border
                Padding="5"
                Background="LightYellow"
                BorderBrush="Gray"
                BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="32"
                        Height="32"
                        Margin="0,0,5,0"
                        Source="{StaticResource ResourceKey=IconOffice_Page_PDF_64}" />

                    <TextBlock
                        x:Name="PopupText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="Medium">
                        <Run Text="{Binding Path=DragDropTooltipText}" />
                        <LineBreak />
                        <Run Text="{Binding Path=FileSizeTooltip}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Popup>
        <!--#endregion-->

        <!--#region Hauptmenübar-->
        <GroupBox
            x:Name="MainMenubar"
            Grid.Row="0"
            Margin="5"
            Padding="5">
            <GroupBox.Template>
                <ControlTemplate TargetType="GroupBox">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </GroupBox.Template>
            <DockPanel Grid.Row="0" Grid.Column="0">
                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=GoBackCommand}"
                    CommandParameter="{x:Static core:CommandButtons.GoBack}"
                    ToolTip="Zurück">
                    <Image Source="{StaticResource ResourceKey=IconGoBack}" Stretch="Uniform" />
                </Button>

                <Border
                    Width="1"
                    Margin="5,0,0,0"
                    Background="Gray" />

                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=OpenFolderCommand}"
                    CommandParameter="{x:Static core:CommandButtons.OpenFolder}"
                    ToolTip="Ordner öffnen">
                    <Image Source="{StaticResource ResourceKey=IconOffice_Folder_open_64}" Stretch="Uniform" />
                </Button>

                <base:ZoomComboBox
                    Height="25"
                    Margin="5,0,0,0"
                    ResultSelection="{Binding Path=SelectionZoom, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                <TextBlock Margin="5,0,0,0" VerticalAlignment="Center">
                    <Run Text="Anzahl Seiten" />
                    <Run Text=":" />
                    <Run Text="{Binding Path=PDFPageInfo, FallbackValue=0/0}" />
                </TextBlock>

                <Border
                    Width="1"
                    Margin="5,0,0,0"
                    Background="Gray" />

                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=PlusPageCommand}"
                    CommandParameter="{x:Static core:CommandButtons.PlusPage}"
                    ToolTip="Ordner öffnen">
                    <Image Source="{StaticResource ResourceKey=IconSoftware_Plus2}" Stretch="Uniform" />
                </Button>

                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=MinusPageCommand}"
                    CommandParameter="{x:Static core:CommandButtons.MinusPage}"
                    ToolTip="Ordner öffnen">
                    <Image Source="{StaticResource ResourceKey=IconSoftware_Minus2}" Stretch="Uniform" />
                </Button>

                <Border
                    Width="1"
                    Margin="5,0,0,0"
                    Background="Gray" />

                <base:ChooseBox
                    Title="Merge PDF speichern unter ..."
                    Width="300"
                    Height="25"
                    Margin="5,0,0,0"
                    ChooseBoxType="SaveFile"
                    DefaultExtension="PDF File|*.pdf"
                    ExtensionFilter="PDF File|*.pdf"
                    Text="{Binding Path=SplittFilename, FallbackValue=SplittFilename}" />

                <Button
                    Width="{StaticResource ResourceKey=ButtonSize}"
                    Height="{StaticResource ResourceKey=ButtonSize}"
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Command="{Binding Path=SavePDFCommand}"
                    CommandParameter="{x:Static core:CommandButtons.SavePDF}"
                    ToolTip="PDF speichern">
                    <Image Source="{StaticResource ResourceKey=IconOffice_Save_as_PDF_64}" Stretch="Uniform" />
                </Button>
            </DockPanel>
        </GroupBox>
        <!--#endregion Hauptmenübar-->

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            ColumnDefinitions="Auto,Auto,*"
            RowDefinitions="*">
            <ListBox
                x:Name="ListBoxFiles"
                Grid.Row="0"
                Grid.Column="0"
                Width="250"
                Margin="5"
                AllowDrop="True"
                DragLeave="ListBoxFiles_DragLeave"
                DragOver="ListBoxFiles_DragOver"
                Drop="ListBoxFiles_Drop"
                ItemsSource="{Binding Path=PDFFilesSource}"
                MouseMove="ListBoxFiles_MouseMove"
                PreviewMouseLeftButtonDown="ListBoxFiles_PreviewMouseLeftButtonDown"
                SelectedItem="{Binding Path=SelectedPdfFile, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Horizontal">
                            <CheckBox VerticalAlignment="Center" IsChecked="{Binding Path=IsSelectedItem, Mode=TwoWay}" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding Path=Filename}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--#region Drag and Drop Line Overlay-->
            <Canvas x:Name="DrogDropLineOverlay" IsHitTestVisible="False">
                <!--  Einfügelinie  -->
                <Line
                    x:Name="InsertLine"
                    Stroke="DodgerBlue"
                    StrokeThickness="2"
                    Visibility="Collapsed" />

                <!--  Linker Pfeil  -->
                <Polygon
                    x:Name="LeftArrow"
                    Fill="DodgerBlue"
                    Stroke="DodgerBlue"
                    StrokeThickness="1"
                    Visibility="Collapsed" />

                <!--  Rechter Pfeil  -->
                <Polygon
                    x:Name="RightArrow"
                    Fill="DodgerBlue"
                    Stroke="DodgerBlue"
                    StrokeThickness="1"
                    Visibility="Collapsed" />
            </Canvas>
            <!--#endregion Drag and Drop Line Overlay-->

            <Border
                Grid.Column="1"
                Margin="0,5,0,5"
                BorderBrush="Gray"
                BorderThickness="1">
                <Grid
                    Grid.Column="1"
                    Background="LightBlue"
                    ColumnDefinitions="150"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,auto,auto,*">
                    <TextBlock
                        Grid.Row="0"
                        Margin="5,0,0,0"
                        FontSize="13"
                        FontWeight="Medium"
                        Text="Angaben, wie PDF gesplittet werden soll"
                        TextWrapping="Wrap" />

                    <Border
                        Grid.Row="1"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />

                    <StackPanel
                        Grid.Row="2"
                        Margin="5,5,0,0"
                        Orientation="Horizontal">
                        <TextBlock FontWeight="Medium" Text="Alle Seite" />
                        <CheckBox Margin="5,0,0,0" IsChecked="{Binding Path=SplittAllPages, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Border
                        Grid.Row="3"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />

                    <TextBlock
                        Grid.Row="4"
                        Margin="5,5,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Text="Einzelne Seiten/Bereich" />

                    <TextBox
                        Grid.Row="5"
                        Width="140"
                        Height="25"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{Binding Path=SinglePages, UpdateSourceTrigger=PropertyChanged}" />

                    <Border
                        Grid.Row="6"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />

                    <TextBlock
                        Grid.Row="7"
                        Margin="5,5,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Text="Dateikennzeichnung: z.B. &lt;Dateiname&gt;_seite_n.pdf"
                        TextWrapping="Wrap" />

                    <TextBox
                        Grid.Row="8"
                        Width="140"
                        Height="25"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{Binding Path=FileSuffix, UpdateSourceTrigger=PropertyChanged}" />

                    <Border
                        Grid.Row="9"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />

                    <TextBlock
                        Grid.Row="10"
                        Margin="5,5,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Text="Bereich von Seiten extrahieren"
                        TextWrapping="Wrap" />

                    <TextBox
                        Grid.Row="11"
                        Width="140"
                        Height="25"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{Binding Path=ExtractRangePages, UpdateSourceTrigger=PropertyChanged}" />

                    <Border
                        Grid.Row="12"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />

                    <Button
                        Grid.Row="13"
                        Width="{StaticResource ResourceKey=ButtonSize}"
                        Height="{StaticResource ResourceKey=ButtonSize}"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        Command="{Binding Path=OpenFolderCommand}"
                        CommandParameter="{x:Static core:CommandButtons.OpenFolder}"
                        ToolTip="Eingaben zurücksetzten">
                        <Image Source="{StaticResource ResourceKey=IconReset}" Stretch="Uniform" />
                    </Button>

                    <Border
                        Grid.Row="14"
                        Height="1"
                        Margin="0,5,0,0"
                        Background="Gray" />
                </Grid>
            </Border>

            <ScrollViewer
                Grid.Row="0"
                Grid.Column="2"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Border
                    Margin="5,5,5,5"
                    BorderBrush="Gray"
                    BorderThickness="1">
                    <Image
                        x:Name="PdfImage"
                        Grid.Row="0"
                        Grid.Column="1"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        RenderOptions.EdgeMode="Aliased"
                        Stretch="None" />
                </Border>
            </ScrollViewer>

        </Grid>

    </Grid>
</base:UserControlBase>
