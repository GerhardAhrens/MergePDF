<base:WindowBase
    x:Class="MergePDF.View.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MergePDF.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}"
    Width="950"
    Height="600"
    mc:Ignorable="d">

    <Grid
        x:Name="gridMain"
        ColumnDefinitions="*"
        RowDefinitions="*,35">

        <!--#region Contentbereich-->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Background="White"
            BorderBrush="Black"
            BorderThickness="0,1,0,1">
            <ContentControl
                x:Name="mainContent"
                Margin="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="LightGray"
                Content="{Binding Path=WorkContent, UpdateSourceTrigger=PropertyChanged}"
                ScrollViewer.CanContentScroll="True"
                VirtualizingPanel.IsVirtualizing="True"
                Visibility="Visible" />
        </Border>
        <!--#endregion Contentbereich-->

        <!--#region Statuszeile-->
        <StatusBar
            Grid.Row="2"
            Height="Auto"
            Background="Transparent"
            BorderBrush="DarkGray"
            BorderThickness="2"
            DataContext="StatusMain"
            FontSize="13">

            <StatusBarItem DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal">
                    <Label Content="{StaticResource ResourceKey=IconStatusbarUser}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Path=CurrentUser, Source={x:Static base:StatusbarMain.Statusbar}}" />
                </StackPanel>
            </StatusBarItem>

            <Separator Background="DarkGray" />

            <StatusBarItem DockPanel.Dock="Left" ToolTip="{Binding Path=DatabaseInfoTooltip, Source={x:Static base:StatusbarMain.Statusbar}}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{StaticResource ResourceKey=IconSoftware_Folder_Open}" />

                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Path=DatabaseInfo, Source={x:Static base:StatusbarMain.Statusbar}}" />
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem DockPanel.Dock="Right">
                <StackPanel Orientation="Horizontal">
                    <Label Content="{StaticResource ResourceKey=IconStatusbarCalendar}" />
                    <TextBlock
                        x:Name="dtStatusBarDate"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Path=CurrentDate, Source={x:Static base:StatusbarMain.Statusbar}}" />
                </StackPanel>
            </StatusBarItem>

            <Separator Background="DarkGray" />

            <StatusBarItem DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal">
                    <Label Content="{StaticResource ResourceKey=IconStatusbarNotification}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Path=Notification, Source={x:Static base:StatusbarMain.Statusbar}}" />
                </StackPanel>
            </StatusBarItem>

        </StatusBar>
        <!--#endregion Statuszeile-->
    </Grid>
</base:WindowBase>
