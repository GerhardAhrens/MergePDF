<Application x:Class="MergePDF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MergePDF"
             StartupUri="View\MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Alle Styles sammeln und mergen  -->

                <!--  Lokale Styles  -->
                <ResourceDictionary Source="Resources\Style\Pictures.xaml" />
                <ResourceDictionary Source="Resources\Style\XamlIcon.xaml" />
                <ResourceDictionary Source="Resources\Style\ApplicationResources.xaml" />
                <ResourceDictionary Source="Resources\Localization\Localization.xaml" />
                <ResourceDictionary Source="TemplateCore\Themes\Generic.xaml" />
                <ResourceDictionary Source="Core\Controls\Themes\Generic.xaml" />

                <!--  Externe Styles aus Bibliotheken  -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
