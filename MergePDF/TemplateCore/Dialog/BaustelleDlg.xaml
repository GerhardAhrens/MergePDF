    <Grid
        Margin="10"
        ColumnDefinitions="150,*"
        RowDefinitions="Auto,*,auto">


        <TextBlock
            x:Name="TB_Titel"
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,0,0,10"
            FontSize="16"
            FontWeight="Bold"
            Text="~Titel" />

        <Line
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,10,0,0"
            VerticalAlignment="Center"
            Stretch="Fill"
            Stroke="Black"
            StrokeThickness="2"
            X1="0"
            X2="1"
            Y1="0"
            Y2="0" />

        <TextBlock
            x:Name="TB_Message"
            Grid.Row="1"
            Grid.Column="1"
            Margin="10"
            FontSize="13"
            FontWeight="Medium"
            Text="~Message"
            TextWrapping="WrapWithOverflow" />

        <Image
            Grid.Row="1"
            Width="150"
            Height="150"
            Source="{StaticResource ResourceKey=IconSoftware_Under_construction}" />

        <Button
            Grid.Row="2"
            Grid.Column="1"
            Width="50"
            Height="50"
            Margin="5,0,0,0"
            HorizontalAlignment="Right"
            Background="Transparent"
            BorderBrush="Transparent"
            Click="BtnOk_Click"
            ToolTip="Dialog bestätigen">
            <Image Source="{StaticResource ResourceKey=IconSoftware_Check}" Stretch="Uniform" />
        </Button>

    </Grid>
</Window>
