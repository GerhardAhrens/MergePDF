<Window
    x:Class="System.Windows.NotificationBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    MinWidth="154"
    MinHeight="155"
    MaxWidth="470"
    x:ClassModifier="internal"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    Topmost="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid
            Grid.Row="0"
            MinHeight="69"
            Background="White">
            <DockPanel>
                <Image
                    Name="Image_MessageBox"
                    Width="32"
                    Height="32"
                    Margin="30,20,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    DockPanel.Dock="Left"
                    Visibility="Collapsed" />
                <TextBlock
                    Name="TextBlock_Message"
                    Width="Auto"
                    MaxWidth="500"
                    Margin="12,11,41,15"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap" />
            </DockPanel>
        </Grid>
        <Grid
            Grid.Row="1"
            MinHeight="49"
            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <DockPanel Margin="5,0">

                <!--  Cancel Button  -->
                <Button
                    Name="Button_Cancel"
                    Height="26"
                    MinWidth="88"
                    MaxWidth="160"
                    Margin="5,0"
                    HorizontalAlignment="Right"
                    Click="Button_Cancel_Click"
                    DockPanel.Dock="Right"
                    IsCancel="True"
                    Visibility="Collapsed">
                    <Label
                        Name="Label_Cancel"
                        Margin="10,0"
                        Padding="0">
                        _Abrechen
                    </Label>
                </Button>
                <!--  End Cancel Button  -->

                <!--  No Button  -->
                <Button
                    Name="Button_No"
                    Height="26"
                    MinWidth="88"
                    MaxWidth="160"
                    Margin="5,0"
                    HorizontalAlignment="Right"
                    Click="Button_No_Click"
                    DockPanel.Dock="Right"
                    Visibility="Collapsed">
                    <Label
                        Name="Label_No"
                        Margin="10,0"
                        Padding="0">
                        _Nein
                    </Label>
                </Button>
                <!--  End No Button  -->

                <!--  Yes Button  -->
                <Button
                    Name="Button_Yes"
                    Height="26"
                    MinWidth="88"
                    MaxWidth="160"
                    Margin="35,0,5,0"
                    HorizontalAlignment="Right"
                    Click="Button_Yes_Click"
                    DockPanel.Dock="Right"
                    Visibility="Collapsed">
                    <Label
                        Name="Label_Yes"
                        Margin="10,0"
                        Padding="0">
                        _Ja
                    </Label>
                </Button>
                <!--  End Yes Button  -->

                <!--  OK Button  -->
                <Button
                    Name="Button_OK"
                    Height="26"
                    MinWidth="88"
                    MaxWidth="160"
                    Margin="35,0,5,0"
                    HorizontalAlignment="Right"
                    Click="Button_OK_Click">
                    <Label
                        Name="Label_Ok"
                        Margin="10,0"
                        Padding="0">
                        _OK
                    </Label>
                </Button>
                <!--  End OK Button  -->

            </DockPanel>
        </Grid>
    </Grid>
</Window>
